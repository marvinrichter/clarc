{
  "name": "clarc",
  "version": "1.7.0",
  "description": "Production-grade Claude Code workflow OS — agents, skills, hooks, commands, rules, and a continuous learning flywheel for modern software engineering.",
  "keywords": [
    "claude-code",
    "ai",
    "agents",
    "skills",
    "hooks",
    "mcp",
    "rules",
    "claude",
    "anthropic",
    "tdd",
    "code-review",
    "security",
    "automation",
    "best-practices",
    "cursor",
    "cursor-ide",
    "opencode",
    "codex",
    "presentations",
    "slides"
  ],
  "author": {
    "name": "Marvin Richter"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marvinrichter/clarc.git"
  },
  "homepage": "https://github.com/marvinrichter/clarc#readme",
  "bugs": {
    "url": "https://github.com/marvinrichter/clarc/issues"
  },
  "files": [
    ".agents/",
    ".codex/",
    ".cursor/",
    ".opencode/commands/",
    ".opencode/instructions/",
    ".opencode/plugins/",
    ".opencode/prompts/",
    ".opencode/tools/",
    ".opencode/index.ts",
    ".opencode/opencode.json",
    ".opencode/package.json",
    ".opencode/tsconfig.json",
    ".opencode/MIGRATION.md",
    ".opencode/README.md",
    "agents/",
    "commands/",
    "contexts/",
    "examples/CLAUDE.md",
    "examples/user-CLAUDE.md",
    "examples/statusline.json",
    "hooks/",
    "mcp-configs/",
    "plugins/",
    "rules/",
    "schemas/",
    "scripts/ci/",
    "scripts/hooks/",
    "scripts/lib/",
    "scripts/claw.js",
    "scripts/setup-package-manager.js",
    "scripts/skill-create-output.js",
    "scripts/sync-instincts.js",
    "skills/",
    "AGENTS.md",
    ".claude-plugin/plugin.json",
    ".claude-plugin/README.md",
    "install.sh",
    "llms.txt",
    "scripts/hooks-summary.js"
  ],
  "bin": {
    "clarc-install": "install.sh"
  },
  "scripts": {
    "postinstall": "echo '\\n  clarc installed!\\n  Run: npx clarc-install typescript\\n'",
    "lint": "eslint . && markdownlint '**/*.md' --ignore node_modules",
    "claw": "node scripts/claw.js",
    "instincts:push": "node scripts/sync-instincts.js push",
    "instincts:pull": "node scripts/sync-instincts.js pull",
    "instincts:push:md": "node scripts/sync-instincts.js push --md",
    "instincts:pull:md": "node scripts/sync-instincts.js pull --md",
    "instincts:status": "node scripts/sync-instincts.js status",
    "test": "node scripts/ci/validate-agents.js && node scripts/ci/validate-commands.js && node scripts/ci/validate-rules.js && node scripts/ci/validate-skills.js && node scripts/ci/validate-hooks.js && node tests/run-all.js",
    "hooks:summary": "node scripts/hooks-summary.js",
    "hooks:errors": "node scripts/hooks-summary.js --errors"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "globals": "^17.1.0",
    "markdownlint-cli": "^0.47.0"
  },
  "engines": {
    "node": ">=18"
  }
}

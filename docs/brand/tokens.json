{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "brand": "clarc",
    "version": "1.0.0",
    "personality": ["Precise", "Structural", "Inevitable"],
    "colorSystem": "Blueprint — hue 216° primary, 162° accent"
  },
  "color": {
    "primary": {
      "50":  { "$value": "hsl(216, 80%, 96%)", "$type": "color" },
      "100": { "$value": "hsl(216, 80%, 91%)", "$type": "color" },
      "200": { "$value": "hsl(216, 80%, 80%)", "$type": "color" },
      "300": { "$value": "hsl(216, 80%, 66%)", "$type": "color" },
      "400": { "$value": "hsl(216, 80%, 54%)", "$type": "color" },
      "500": { "$value": "hsl(216, 80%, 40%)", "$type": "color", "$description": "Brand primary — WCAG AA on white ~6.3:1" },
      "600": { "$value": "hsl(216, 80%, 30%)", "$type": "color", "$description": "WCAG AAA on white ~8.9:1" },
      "700": { "$value": "hsl(216, 80%, 22%)", "$type": "color" },
      "800": { "$value": "hsl(216, 80%, 14%)", "$type": "color" },
      "900": { "$value": "hsl(216, 80%, 08%)", "$type": "color" }
    },
    "accent": {
      "50":  { "$value": "hsl(162, 60%, 95%)", "$type": "color" },
      "100": { "$value": "hsl(162, 60%, 88%)", "$type": "color" },
      "200": { "$value": "hsl(162, 60%, 74%)", "$type": "color" },
      "300": { "$value": "hsl(162, 60%, 58%)", "$type": "color" },
      "400": { "$value": "hsl(162, 60%, 46%)", "$type": "color" },
      "500": { "$value": "hsl(162, 60%, 38%)", "$type": "color", "$description": "Decorative/icon use — not for body text on white" },
      "600": { "$value": "hsl(162, 65%, 28%)", "$type": "color", "$description": "WCAG AA on white ~5.1:1" },
      "700": { "$value": "hsl(162, 65%, 20%)", "$type": "color" }
    },
    "neutral": {
      "0":   { "$value": "hsl(216, 0%, 100%)",  "$type": "color" },
      "50":  { "$value": "hsl(216, 20%, 97%)",  "$type": "color" },
      "100": { "$value": "hsl(216, 16%, 93%)",  "$type": "color" },
      "200": { "$value": "hsl(216, 14%, 85%)",  "$type": "color" },
      "300": { "$value": "hsl(216, 12%, 72%)",  "$type": "color" },
      "400": { "$value": "hsl(216, 10%, 56%)",  "$type": "color" },
      "500": { "$value": "hsl(216, 9%, 42%)",   "$type": "color" },
      "600": { "$value": "hsl(216, 9%, 30%)",   "$type": "color" },
      "700": { "$value": "hsl(216, 10%, 20%)",  "$type": "color" },
      "800": { "$value": "hsl(216, 12%, 13%)",  "$type": "color" },
      "900": { "$value": "hsl(216, 14%, 8%)",   "$type": "color" },
      "950": { "$value": "hsl(216, 16%, 5%)",   "$type": "color" }
    },
    "semantic": {
      "success": { "$value": "hsl(142, 58%, 36%)", "$type": "color" },
      "warning":  { "$value": "hsl(38, 90%, 44%)",  "$type": "color" },
      "error":    { "$value": "hsl(4, 78%, 44%)",   "$type": "color" },
      "info":     { "$value": "hsl(216, 80%, 40%)", "$type": "color" }
    }
  },
  "font": {
    "display": { "$value": "'Space Grotesk', 'Inter', system-ui, sans-serif", "$type": "fontFamily" },
    "body":    { "$value": "'Inter', system-ui, -apple-system, sans-serif", "$type": "fontFamily" },
    "mono":    { "$value": "'Geist Mono', 'JetBrains Mono', 'Fira Code', ui-monospace, monospace", "$type": "fontFamily" }
  },
  "fontSize": {
    "xs":   { "$value": "0.64rem",  "$type": "dimension" },
    "sm":   { "$value": "0.8rem",   "$type": "dimension" },
    "base": { "$value": "1rem",     "$type": "dimension" },
    "lg":   { "$value": "1.25rem",  "$type": "dimension" },
    "xl":   { "$value": "1.563rem", "$type": "dimension" },
    "2xl":  { "$value": "1.953rem", "$type": "dimension" },
    "3xl":  { "$value": "2.441rem", "$type": "dimension" },
    "4xl":  { "$value": "3.052rem", "$type": "dimension" },
    "5xl":  { "$value": "3.815rem", "$type": "dimension" }
  }
}
